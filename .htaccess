# Nanoportal — Apache headers for tablet photobooth (HTTPS site root).
# Requires: a2enmod headers

<IfModule mod_headers.c>
  # Allow getUserMedia on this origin (tablet admin over HTTPS).
  Header always set Permissions-Policy "camera=(self), microphone=()"
  Header always set Feature-Policy "camera 'self'; microphone 'none'"
</IfModule>

# SSE — keep long-lived /api/events.php connections alive.
# TimeOut / KeepAliveTimeout are best set in the vhost (e.g. TimeOut 300).
<Files "events.php">
  <IfModule mod_headers.c>
    Header set X-Accel-Buffering "no"
    Header set Cache-Control "no-store"
  </IfModule>
  <IfModule mod_deflate.c>
    SetEnv no-gzip 1
  </IfModule>
</Files>
