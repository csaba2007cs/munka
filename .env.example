# Copy to .env and fill in ( .env is gitignored )

# API write protection — POST /api/state.php, upload.php, audio.php
# Leave empty for open LAN dev mode (no token required).
NANOPORTAL_API_TOKEN=

# ElevenLabs TTS — névfelolvasás (api/audio.php action: tts_names)
ELEVENLABS_API_KEY=
# Optional voice ID (default: Adam). HU support: verify on elevenlabs.io
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Dev server (optional)
# PORT=8787
# HOST=127.0.0.1

# data/ retention limits (upload + TTS prune after each write)
MAX_PHOTOBOOTH_FILES=100
MAX_VISITOR_FILES=50
MAX_WINDOW_FILES=30
MAX_TTS_FILES=20

# MQTT notify after visitor registration (mosquitto_pub on server)
# MQTT_BROKER_HOST=127.0.0.1
# MQTT_BROKER_PORT=1883
# MQTT_BROKER_USER=
# MQTT_BROKER_PASS=
