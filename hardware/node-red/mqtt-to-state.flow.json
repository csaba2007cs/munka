  },
  {
    "id": "fn_build_patch",
    "type": "function",
    "z": "nanoportal_tab",
    "name": "Build patch + HTTP opts",
    "func": "const baseUrl = env.get('STATE_URL') || 'http://127.0.0.1/api/state.php';\nconst raw = msg.payload;\nlet patch = {};\n\nif (raw && typeof raw === 'object' && !Array.isArray(raw)) {\n  if (raw.hardware) {\n    patch = { hardware: raw.hardware };\n  } else if (raw.display || raw.status || raw.quiz_state || raw.audio || raw.screens || raw.visitors || raw.group_contact) {\n    patch = raw;\n  } else {\n    patch = {\n      hardware: {\n        last_sensor_event: {\n          device: String(raw.device || 'esp32'),\n          type: String(raw.type || 'event'),\n          at: raw.at || new Date().toISOString()\n        }\n      }\n    };\n  }\n} else {\n  patch = {\n    hardware: {\n      last_sensor_event: {\n        device: 'mqtt',\n        type: String(raw),\n        at: new Date().toISOString()\n      }\n    }\n  };\n}\n\nmsg.payload = patch;\nmsg.method = 'POST';\nmsg.url = baseUrl;\nmsg.headers = { 'Content-Type': 'application/json' };\nreturn msg;",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 400,
    "y": 140,
    "wires": [["http_post_state"]]
  },
  {
